FROM python:3.12-slim

WORKDIR /app

# Dependências do sistema (adicionado tzdata para fuso horário)
RUN apt-get update && apt-get install -y \
  curl \
  tzdata \
  && rm -rf /var/lib/apt/lists/*

# Configura o fuso horário correto
ENV TZ=America/Sao_Paulo

# Configura o Linux para preferir IPv4 contra lentidão de rede
RUN echo "precedence ::ffff:0:0/96  100" >> /etc/gai.conf

# Instala uv
RUN curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR="/usr/local/bin" sh

# Copia apenas dependências primeiro
COPY backend/pyproject.toml backend/uv.lock* ./ 

# Instala dependências (ajuste conforme seu setup)
RUN pip install --no-cache-dir uv \
  && uv pip install --system .

# Copia código do backend
COPY backend/ .

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]