# ===== BUILD =====
FROM node:20-bullseye AS builder

WORKDIR /app

RUN npm install -g pnpm

COPY package.json pnpm-lock.yaml ./
COPY patches ./patches

# Força o pnpm a criar pastas físicas em vez de atalhos
RUN echo "node-linker=hoisted" > .npmrc

# O frozen-lockfile obriga o pnpm a respeitar os patches à risca
RUN pnpm install --frozen-lockfile

COPY . .

# ===== ENV VARS (BUILD TIME) =====
ARG NEXT_PUBLIC_SUPABASE_URL
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY
ARG NEXT_PUBLIC_SITE_URL
ARG NEXT_PUBLIC_API_URL
ARG LANGGRAPH_DEPLOYMENT_URL
ARG LANGSMITH_API_KEY

ENV NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL
ENV NEXT_PUBLIC_SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY
ENV NEXT_PUBLIC_SITE_URL=$NEXT_PUBLIC_SITE_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV LANGGRAPH_DEPLOYMENT_URL=$LANGGRAPH_DEPLOYMENT_URL
ENV LANGSMITH_API_KEY=$LANGSMITH_API_KEY

RUN pnpm build:turbopack


# ===== RUN (PRODUÇÃO OTIMIZADA E BLINDADA) =====
FROM node:20-bullseye-slim

WORKDIR /app

# 1. Instala o banco de dados de fuso horário para o horário de Brasília funcionar
RUN apt-get update && apt-get install -y tzdata && rm -rf /var/lib/apt/lists/*
ENV TZ=America/Sao_Paulo

# 2. Variáveis originais do Next.js
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# 3. Vacina do IPv4 para o Node.js não dar timeout (Erro: other side closed) na Azure
ENV NODE_OPTIONS="--dns-result-order=ipv4first"

# Copia os artefatos do builder
COPY --from=builder /app/public ./public
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static

EXPOSE 3000

CMD ["node", "server.js"]